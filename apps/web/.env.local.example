# Public — inlined into the client bundle. Get a token at mapbox.com.
NEXT_PUBLIC_MAPBOX_TOKEN=pk.placeholder_token

# Public — PostHog analytics. Leave KEY blank to disable analytics.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Server — Supabase. SERVICE_ROLE bypasses RLS, never expose to client.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Server — Anthropic API for ranking. Without it, /api/experiences/nearby
# falls back to soloScore-based ranking.
ANTHROPIC_API_KEY=
