{
  "name": "@solo-compass/db",
  "version": "0.0.1",
  "private": true,
  "description": "Drizzle ORM schema and migrations for Solo Compass",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "db:up": "docker compose -f ../../docker-compose.yml up -d",
    "db:migrate": "drizzle-kit migrate",
    "db:generate": "drizzle-kit generate",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "drizzle-orm": "^0.36.0",
    "postgres": "^3.4.4"
  },
  "devDependencies": {
    "drizzle-kit": "^0.28.0",
    "typescript": "^5.6.2"
  }
}
